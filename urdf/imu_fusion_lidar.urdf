<?xml version="1.0"?>
<robot name="lidar_imu_robot">

  <!-- Base frame -->
  <link name="base_link"/>

  <!-- LiDAR frame -->
  <link name="laser"/>

  <!-- IMU frame -->
  <link name="imu_link"/>


  <!-- base -> lidar -->
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>

    <!-- vị trí lidar -->
    <origin xyz="0.0 0 0.05" rpy="0 0 3.1416"/>
  </joint>


  <!-- base -> imu -->
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>

    <!-- vị trí imu -->
    <origin xyz="0 0 0" rpy="0 0 -1.578"/>
  </joint>

</robot>